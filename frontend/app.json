{
  "expo": {
    "name": "RozgarSaathi",
    "slug": "rozgarsaathi",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "rozgarsaathi",
    "splash": {
      "backgroundColor": "#22C55E",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rozgarsaathi.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#22C55E"
      },
      "package": "com.rozgarsaathi.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
